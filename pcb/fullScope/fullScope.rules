
(rules PCB fullScope.dsn
  (snap_angle 
    fortyfive_degree
  )
  (rule
    (width 400.0)
    (clearance 200.0)
    (clearance 200.0 (type smd_to_turn_gap))
    (clearance 50.0 (type smd))
    (clearance 200.0 (type "kicad_default"))
  )
  (padstack "Via[0-1]_800:400_um"
    (shape
      (circle F.Cu 800.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 800.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-1]_800:400_um" "Via[0-1]_800:400_um" default
  )
  (via 
    "Via[0-1]_800:400_um-kicad_default" "Via[0-1]_800:400_um" "kicad_default"
  )
  (via_rule
    default "Via[0-1]_800:400_um"
  )
  (via_rule
    "kicad_default" "Via[0-1]_800:400_um-kicad_default"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 400.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class "kicad_default"
    "Net-(D1-COM)" "Net-(R4-Pad2)" +5V GND "Net-(U1A--)" "FE_OUT" BTN1 "Net-(U1B--)"
    +3.3V +9V "unconnected-(J2-Pin_5-Pad5)" "unconnected-(J2-Pin_7-Pad7)" "unconnected-(J2-Pin_8-Pad8)" "unconnected-(J2-Pin_9-Pad9)" "unconnected-(J2-Pin_10-Pad10)" "unconnected-(J2-Pin_11-Pad11)"
    "unconnected-(J2-Pin_12-Pad12)" "unconnected-(J2-Pin_13-Pad13)" "unconnected-(J2-Pin_14-Pad14)" "unconnected-(J2-Pin_15-Pad15)" "unconnected-(J2-Pin_16-Pad16)" "unconnected-(J2-Pin_17-Pad17)" "unconnected-(J2-Pin_18-Pad18)" "unconnected-(J2-Pin_19-Pad19)"
    "unconnected-(J2-Pin_20-Pad20)" "unconnected-(J2-Pin_21-Pad21)" "unconnected-(J2-Pin_22-Pad22)" "unconnected-(J2-Pin_23-Pad23)" "unconnected-(J2-Pin_24-Pad24)" "unconnected-(J2-Pin_25-Pad25)" "unconnected-(J2-Pin_26-Pad26)" "unconnected-(J2-Pin_27-Pad27)"
    "unconnected-(J2-Pin_28-Pad28)" "unconnected-(J2-Pin_29-Pad29)" "unconnected-(J2-Pin_30-Pad30)" IN+ "Net-(SW4-B)" "Net-(SW4-C)" "unconnected-(J4-Pin_1-Pad1)" "unconnected-(J4-Pin_2-Pad2)"
    "unconnected-(J4-Pin_3-Pad3)" "unconnected-(J4-Pin_4-Pad4)" "unconnected-(J4-Pin_5-Pad5)" "unconnected-(J4-Pin_6-Pad6)" "unconnected-(J4-Pin_9-Pad9)" "unconnected-(J4-Pin_10-Pad10)" "unconnected-(J4-Pin_11-Pad11)" DC
    RES "unconnected-(J4-Pin_15-Pad15)" CS "unconnected-(J4-Pin_17-Pad17)" SCK "unconnected-(J4-Pin_19-Pad19)" MOSI "unconnected-(J4-Pin_21-Pad21)"
    "unconnected-(J4-Pin_22-Pad22)" "unconnected-(J4-Pin_23-Pad23)" "unconnected-(J4-Pin_24-Pad24)" BTN2 BTN3 "unconnected-(J4-Pin_27-Pad27)" "unconnected-(J4-Pin_28-Pad28)" "unconnected-(J4-Pin_29-Pad29)"
    "unconnected-(J4-Pin_30-Pad30)" "unconnected-(J4-Pin_31-Pad31)" "unconnected-(J4-Pin_32-Pad32)" "unconnected-(J4-Pin_33-Pad33)" "unconnected-(J4-Pin_35-Pad35)"
    (clearance_class "kicad_default")
    (via_rule "kicad_default")
    (rule
      (width 400.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
)